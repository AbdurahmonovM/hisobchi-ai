# ===== Telegram =====
BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
# Public HTTPS URL serving the Web App.
#  - Railway:  https://<your-service>.up.railway.app  (Railway gives this)
#  - Local dev: ngrok http 8000  ->  https://xxxx.ngrok-free.app
WEB_APP_URL=https://your-service.up.railway.app

# "polling" for local dev (run bot.py separately), "webhook" for Railway (main.py).
BOT_MODE=webhook
# Long random string — protects the webhook endpoint. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=put-a-long-random-string-here

# ===== AI provider (STT + NLP) =====
# "groq" = FREE (Groq Whisper + Llama). "openai" = paid.
AI_PROVIDER=groq

# FREE key from https://console.groq.com/keys  (covers BOTH speech + NLP)
GROQ_API_KEY=gsk_your-free-groq-key

# Only needed if AI_PROVIDER=openai
OPENAI_API_KEY=

# Optional model overrides (leave empty to use free per-provider defaults:
#   groq -> whisper-large-v3-turbo + llama-3.3-70b-versatile)
WHISPER_MODEL=
NLP_MODEL=

# ===== Database =====
# Dev (default): local async SQLite
DATABASE_URL=sqlite+aiosqlite:///./hisobchi.db
# Railway: add a Postgres plugin and reference its URL with:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# (config.py auto-rewrites postgres:// -> postgresql+asyncpg://)

# ===== Server =====
HOST=0.0.0.0
PORT=8000

# ===== Behaviour =====
DEFAULT_CURRENCY=UZS
LOG_LEVEL=INFO
